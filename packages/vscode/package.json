    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "@studnicky/iridis": "^0.6.1"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  }
