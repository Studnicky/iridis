{
  "name": "@studnicky/iridis",
  "version": "0.6.1",
  "type": "module",
  "description": "Pluggable color derivation pipeline. Variable-input-count seed colors expand into role-resolved, contrast-enforced palettes via a sequenced task pipeline. Browser- and Node-safe.",
  "exports": {
    ".": "./src/index.ts",
    "./model": "./src/model/index.ts",
    "./types": "./src/types/index.ts",
    "./registry": "./src/registry/index.ts",
    "./engine": "./src/engine/index.ts",
    "./math": "./src/math/index.ts",
    "./tasks": "./src/tasks/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test 'tests/**/*.test.ts'",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "tsx": "^4.23.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@studnicky/errors": "^4.0.0",
    "@studnicky/json": "^4.0.0",
    "@studnicky/logger": "^4.0.0",
    "@studnicky/types": "^4.0.0",
    "ajv": "^8.20.0",
    "json-schema-to-ts": "^3.1.1"
  }
}
