{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@studnicky/iridis":            ["./src/index.ts"],
      "@studnicky/iridis/*":          ["./src/*/index.ts"],
      "@studnicky/iridis-contrast":   ["../contrast/src/index.ts"],
      "@studnicky/iridis-stylesheet": ["../stylesheet/src/index.ts"],
      "@studnicky/iridis-capacitor":  ["../capacitor/src/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "../contrast/src/**/*", "../stylesheet/src/**/*", "../capacitor/src/**/*"],
  "exclude": ["dist", "node_modules"]
}
